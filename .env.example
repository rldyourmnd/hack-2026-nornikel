# Runtime
APP_ENV=development
APP_BASE_URL=https://изи-никель.рф
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=5173

# Storage
DUCKDB_PATH=data/catalog.duckdb
DUCKDB_MEMORY_LIMIT=2GB
ARTIFACT_ROOT=data/artifacts
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=evidence_units
QDRANT_ENTITY_COLLECTION=evidence_units_entities
MAX_SOURCE_UPLOAD_BYTES=26214400

# LLM
#
# CI and local checks keep this disabled. Runtime deployments can point the
# gateway at any OpenAI-compatible provider supported by LiteLLM.
LLM_ENABLED=false
LLM_API_BASE=
LLM_API_KEY=
LLM_EXTRACTION_MODEL=
LLM_ANSWER_MODEL=
LLM_REASONING_EFFORT=low
LLM_TIMEOUT_S=60
LLM_MAX_RETRIES=1
LLM_MAX_CONCURRENCY=8
LLM_RPS=10
LLM_TOKEN_BUDGET=500000

# Optional second OpenAI-compatible provider for failover / throughput.
LLM_API_BASE_2=
LLM_API_KEY_2=
LLM_MODEL_2=

# Ingest-time graph extraction. `source_packet` is the fast production default;
# `span_budget` performs deeper per-span extraction when build time permits.
LLM_EXTRACTION_ENABLED=false
LLM_EXTRACTION_MODE=source_packet
LLM_SOURCE_PACKET_CHARS=8000
MAX_EXTRACTION_SPANS=400

# Parser and spreadsheet caps
PDF_PARSE_MODE=pypdfium
DOCLING_PARSE_WORKERS=1
INGEST_XLSX_MAX_SHEETS=50
INGEST_XLSX_MAX_ROWS=5000
INGEST_XLSX_MAX_COLUMNS=60
MAX_TABLE_ROWS_PER_SOURCE=400

# Extraction
GLINER_ENABLED=true
SYNC_ENRICHMENT=false
ENTITY_SEMANTIC_FALLBACK=true

# Embeddings
#
# `openai` uses a remote OpenAI-compatible /embeddings API and is preferred for
# no-GPU production stands. `local` is useful for offline development but can be
# slow on CPU-only servers. `fake` keeps tests fully deterministic.
EMBEDDING_BACKEND=openai
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_ID=text-embedding-3-small
EMBEDDING_BATCH=256
EMBEDDING_RPS=32
SPARSE_MODEL_ID=Qdrant/bm25
SPARSE_LANGUAGE=russian
HF_HOME=/app/data/hf-cache

# Optional Yandex embedding backend, if a verified credential is available.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_EMBED_DOC_MODEL=text-embeddings-v2-doc
YANDEX_EMBED_QUERY_MODEL=text-embeddings-v2-query
YANDEX_EMBED_DIM=768
YANDEX_EMBED_RPS=9.5

# Security labels
JURY_ALLOWED_LABELS=public,internal
DEFAULT_SOURCE_LABEL=internal
ALLOWED_SOURCE_LABELS=public,internal,confidential,restricted

# Optional reranker
RERANKER_ENABLED=false
RERANKER_MODEL_ID=BAAI/bge-reranker-v2-m3
RERANKER_BACKEND=onnx

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Frontend
VITE_API_BASE_URL=/api
