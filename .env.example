# Runtime
APP_ENV=development
APP_BASE_URL=https://изи-никель.рф
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=5173

# Storage
DUCKDB_PATH=data/catalog.duckdb
ARTIFACT_ROOT=data/artifacts
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=evidence_units
MAX_SOURCE_UPLOAD_BYTES=26214400
# Demo fixture seeding DEFAULTS OFF so a real-corpus stand never mixes
# synthetic Ni-Cu rows into answers. Tests and `make eval` opt in explicitly.
SEED_SYNTHETIC_FIXTURE=false
SYNTHETIC_SAMPLE_DIR=sample_docs/synthetic

# LLM via Yandex AI Studio (organizer-provided). Stand config: deepseek-v4-flash
# for BOTH answers and extraction (richer detail, cleaner graph typing, ~16-17s
# per call — needs the higher timeout; json_repair covers its non-native JSON).
# aliceai-llm stays available as a fast native-strict-JSON fallback.
# CI keeps LLM_ENABLED=false (deterministic fakes, no network).
LLM_ENABLED=false
# Yandex AI Studio (OpenAI-compatible), model deepseek-4-flash. Legacy
# DATAEYES_API_BASE/KEY still resolve during the transition.
LLM_API_BASE=https://ai.api.cloud.yandex.net/v1
LLM_API_KEY=
LLM_EXTRACTION_MODEL=
LLM_ANSWER_MODEL=
# Optional 2nd provider (dataeyes gpt-5.5): round-robined with the primary
# for ingest throughput + failover on rate limits. Leave blank to disable.
LLM_API_BASE_2=
LLM_API_KEY_2=
LLM_MODEL_2=
LLM_TIMEOUT_S=60
LLM_MAX_RETRIES=1
# Yandex AI Studio quota: 10 CONCURRENT generations — 8 leaves headroom for
# interactive QA while enrichment runs; LLM_RPS paces submissions.
LLM_MAX_CONCURRENCY=8
LLM_RPS=10
LLM_TOKEN_BUDGET=500000
# Ingest-time LLM extraction (separate gate from answer synthesis).
LLM_EXTRACTION_ENABLED=false

# Spreadsheet ingest caps (raise for reference workbooks; 0/unset = defaults)
INGEST_XLSX_MAX_SHEETS=50
INGEST_XLSX_MAX_ROWS=5000
INGEST_XLSX_MAX_COLUMNS=60

# Extraction
GLINER_ENABLED=true
# Background enrichment (false = off-request-thread, true = inline for tests)
SYNC_ENRICHMENT=false
# Semantic entity-resolution fallback (needs EMBEDDING_BACKEND != off)
ENTITY_SEMANTIC_FALLBACK=true

# Optional self-hosted fallback (compose profile "fallback")
OLLAMA_BASE_URL=http://ollama:11434

# Embeddings: local (USER-bge-m3 on CPU) | yandex (AI Studio API) | openai
#   (OpenAI-compatible /embeddings API, e.g. dataeyes — batched, offloads CPU).
# NOTE: local bge-m3 is CPU-bound and slow on small stands; the openai backend
# (below) is the working demo profile after the Yandex key was denied (403).
EMBEDDING_BACKEND=local
EMBEDDING_MODEL_ID=deepvk/USER-bge-m3
SPARSE_MODEL_ID=Qdrant/bm25
# Yandex AI Studio (organizer-provided): dense embeddings + optional LLM via
# the OpenAI-compatible endpoint https://llm.api.cloud.yandex.net/v1
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_EMBED_DOC_MODEL=text-embeddings/latest
YANDEX_EMBED_QUERY_MODEL=text-embeddings/latest
# BM25 stemmer/stopword language for the sparse leg (must match the corpus)
SPARSE_LANGUAGE=russian
# Documented embeddings quota is 10 RPS (AI Studio is NOT in Quota Manager
# self-service — raising it needs a support ticket from the cloud owner).
YANDEX_EMBED_RPS=9.5
HF_HOME=/app/data/hf-cache

# --- OpenAI-compatible embedding profile (working demo stack; uncomment) ---
# EMBEDDING_BACKEND=openai
# EMBEDDING_API_BASE=          # or reuse DATAEYES_API_BASE
# EMBEDDING_API_KEY=           # or reuse DATAEYES_API_KEY
# EMBEDDING_MODEL_ID=text-embedding-3-small
# EMBEDDING_BATCH=32           # dataeyes caps a batch at ~32 (403 above)
# QDRANT_COLLECTION=evidence_oai   # per-model 1536-dim collection

# Security: server-side visibility floor (MANDATORY on the demo stand — never
# trust the frontend jury toggle) + default label for newly ingested sources.
JURY_ALLOWED_LABELS=public,internal
DEFAULT_SOURCE_LABEL=internal

# Reranker (cross-encoder precision stage over hybrid candidates)
RERANKER_ENABLED=false
RERANKER_MODEL_ID=BAAI/bge-reranker-v2-m3
RERANKER_BACKEND=onnx

# Observability (self-hosted Langfuse; SDK v2 callback path)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Security labels
DEFAULT_SOURCE_LABEL=internal
ALLOWED_SOURCE_LABELS=public,internal,confidential,restricted

# Frontend
VITE_API_BASE_URL=/api
